# NED Freight App — environment variables
# Copy to .env and fill in actual values. Never commit .env.
# Production values live in Render dashboard (Settings → Environment).

# ─── Shopify ─────────────────────────────────────────────────────────────────
SHOPIFY_STORE=nedcollections.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Used only for OAuth re-registration of carrier service:
SHOPIFY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── GoSweetSpot (Castle Parcels / Post Haste / Kiwi Express live rate API) ──
# GSS_SITE_ID selects which site/carrier-set the key can reach (multi-site acct).
# 3658643 = the site with the FULL carrier set (Post Haste, Castle Parcels,
# Kiwi Express + Oversize). Verify carriers with:
#   GET https://api.gosweetspot.com/api/availableservices  (headers access_key, site_id)
GSS_ACCESS_KEY=apikey-xxxx-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GSS_SITE_ID=3658643

# ─── Mainfreight Rating API (live Mainfreight M2H + Dailyfreight LCL) ────────
# One key, two accounts: NEDCOLCHC (M2H two-man), NEDCOLDF (LCL palletised).
# Endpoint: POST https://api.mainfreight.com/transport/1.0/customer/rate?region=NZ
MAINFREIGHT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cin7 (read-only stock/sales logging) ───────────────────────────────────
CIN7_USERNAME=NedCollectionsXxxx
CIN7_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CIN7_WEBHOOK_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Microsoft 365 (SharePoint Freight Calculator sheet logging) ────────────
MSSHEET_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MSSHEET_TENANT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MSSHEET_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Origin (warehouse — used for GSS quotes) ───────────────────────────────
# IMPORTANT: warehouse, NOT showroom. Different addresses give different rates.
ORIGIN_STREET=7 Paradyne Place
ORIGIN_SUBURB=Wigram
ORIGIN_CITY=Christchurch
ORIGIN_POSTCODE=8042
ORIGIN_COUNTRY=NZ

# ─── Pricing multipliers (tunable without redeploy) ─────────────────────────
FAF_MULTIPLIER=1.30
GST_MULTIPLIER=1.15
NED_MARKUP=1.10
# Scales raw cart CBM → realistic packed volume before quoting GSS (carton
# walls, void fill). Default 1.6, derived from a 24× ACSR pack ratio.
PACKING_FACTOR=1.6
# Set high to effectively disable free shipping:
FREE_SHIPPING_THRESHOLD=999999

# ─── App config ──────────────────────────────────────────────────────────────
APP_URL=https://ned-freight-app.onrender.com
PORT=10000
